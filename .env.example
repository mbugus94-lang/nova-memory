# ============================================================================
# Nova Memory 2.0 - Environment Configuration
# ============================================================================
# Copy this file to .env and update with your actual values
# DO NOT commit the .env file to version control
# ============================================================================

# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_PATH=./nova_memory.db
DATABASE_BACKUP_PATH=./backups
DATABASE_CLEANUP_INTERVAL=86400  # seconds (24 hours)

# ============================================================================
# API Server Configuration
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false  # Set to true for development
LOG_LEVEL=INFO    # DEBUG, INFO, WARNING, ERROR, CRITICAL

# ============================================================================
# Solana Blockchain Configuration
# ============================================================================
# RPC endpoint options:
# Mainnet: https://api.mainnet-beta.solana.com
# Testnet: https://api.testnet.solana.com
# Devnet: https://api.devnet.solana.com
# Local: http://localhost:8899
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WALLET_PATH=~/.config/solana/id.json
SOLANA_NETWORK=devnet

# Optional: Your wallet public key (for reference)
SOLANA_WALLET_PUBLIC_KEY=

# Optional: License transaction settings
SOLANA_LICENSE_PROGRAM_ID=
SOLANA_LICENSE_PRICE_SOL=0.1

# ============================================================================
# IBM Watsonx AI Configuration (Optional)
# ============================================================================
IBM_WATSONX_ENABLED=false
IBM_WATSONX_API_KEY=
IBM_WATSONX_PROJECT_ID=
IBM_WATSONX_REGION=us-south
IBM_WATSONX_API_VERSION=2024-01-02

# ============================================================================
# Machine Learning / PyTorch Configuration (Optional)
# ============================================================================
ML_ENABLED=false
TORCH_DEVICE=cpu  # cuda or cpu
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_CACHE_DIR=./embeddings_cache

# ============================================================================
# Security & Authentication (Future Use)
# ============================================================================
# API authentication - implement as needed
API_SECRET_KEY=your-secret-key-here-change-in-production
API_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS settings
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_FILE=./logs/nova_memory.log
LOG_MAX_BYTES=10485760    # 10 MB
LOG_BACKUP_COUNT=5
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ============================================================================
# Performance & Optimization
# ============================================================================
# Memory compression settings
COMPRESSION_ENABLED=true
COMPRESSION_MIN_SIZE=1024  # bytes - compress memories larger than this
COMPRESSION_LEVEL=9        # 1-9: higher = better compression but slower

# Database optimization
DATABASE_CACHE_SIZE=1000
DATABASE_JOURNAL_MODE=WAL
DATABASE_SYNC_MODE=NORMAL

# API rate limiting
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60  # seconds

# ============================================================================
# Development Settings
# ============================================================================
DEBUG=false
TESTING=false
ECHO_SQL=false  # Set to true to log SQL queries

# Demo mode - uses in-memory database for testing
DEMO_MODE=false
DEMO_RESET_ON_START=false

# ============================================================================
# Advanced Features
# ============================================================================
ENABLE_VERSIONING=true
ENABLE_AUDIT_LOG=true
ENABLE_WORKFLOW_ORCHESTRATION=true
ENABLE_MULTI_AGENT_COMMUNICATION=true

# Memory metadata
TRACK_ACCESS_PATTERNS=true
TRACK_MEMORY_METRICS=true

# ============================================================================
# External Services Integration
# ============================================================================
# Webhook endpoints (optional)
WEBHOOK_ENABLED=false
WEBHOOK_URL=
WEBHOOK_SECRET=

# Monitoring & Analytics
SENTRY_ENABLED=false
SENTRY_DSN=

# ============================================================================
# Notes
# ============================================================================
# 1. Never commit this file with real secrets to version control
# 2. Use strong, unique values for all secret keys in production
# 3. Rotate secrets regularly
# 4. Use environment-specific configuration for dev/staging/prod
# 5. Consider using a secrets management system (AWS Secrets, Vault, etc.)
