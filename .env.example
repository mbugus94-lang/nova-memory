# Nova Memory Environment Configuration

# Application Settings
APP_NAME=NovaMemory
APP_ENV=development
DEBUG=false

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_RELOAD=false
LOG_LEVEL=INFO

# Security
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET=your-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
NOVA_SECRET_KEY=
NOVA_ADMIN_USERNAME=admin
NOVA_ADMIN_PASSWORD=
NOVA_AGENT_SECRET=nova_agent_secret
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# AI Configuration
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
DEFAULT_AI_MODEL=gpt-4

# Database
DATABASE_URL=sqlite:///./data/nova_memory.db
NOVA_MEMORY_DB_PATH=
DATABASE_BACKUP_PATH=./backups

# Logging
LOG_FILE=logs/nova_memory.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Agent Configuration
MAX_AGENTS=100
AGENT_TIMEOUT_SECONDS=300
HEARTBEAT_INTERVAL_SECONDS=30

# Performance & Optimization
COMPRESSION_ENABLED=true
COMPRESSION_MIN_SIZE=1024
COMPRESSION_LEVEL=9
DATABASE_CACHE_SIZE=1000
DATABASE_JOURNAL_MODE=WAL
DATABASE_SYNC_MODE=NORMAL
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Advanced Features
ENABLE_VERSIONING=true
ENABLE_AUDIT_LOG=true
ENABLE_WORKFLOW_ORCHESTRATION=true
ENABLE_MULTI_AGENT_COMMUNICATION=true
NOVA_CACHE_ENABLED=false
NOVA_CACHE_TTL=3600
NOVA_DEFAULT_TTL=86400
NOVA_ENABLE_SEMANTIC_SEARCH=false
NOVA_ENABLE_ENCRYPTION=false
NOVA_ENABLE_MESSAGING=true
TRACK_ACCESS_PATTERNS=true
TRACK_MEMORY_METRICS=true
